# Shared settings used by both .env.dev and .env.prod overlays.
# SSH_TARGET=ninescoding
# VPS_HOME_PATH=/home/debian
# PROD_DOMAIN=example.com

# Optional: override local LAN IP used for dev cert SAN.
# If empty, Makefile auto-detects from routing table.
LAN_IP=

# Build settings
APP_GOOS=linux
APP_GOARCH=amd64

# TLS cert paths (used only when ENABLE_TLS=true)
TLS_CERT=certs/dev.crt
TLS_KEY=certs/dev.key

IMAGE_SERVICE_PORT=8081
IMAGE_SERVICE_ENDPOINT=/embed
IMAGE_SERVICE_HEALTH_ENDPOINT=/health
IMAGE_SERVICE_WAIT_RETRIES=60
IMAGE_SERVICE_WAIT_SECONDS=1

# Embedding defaults match the ONNX CLIP ViT-B/32 visual encoder we run.
# Keep these aligned with image_service/image_service.py preprocessing:
# - "clip" normalization constants from OpenAI CLIP docs
#   https://github.com/openai/CLIP/blob/main/clip/clip.py#L79-L80
# - 224x224 image size and 512-d output for this model family
# Model file is read through the shared models mount.
EMBED_MODEL_PATH=/models/clip-vit-b-32.onnx
EMBED_MODEL_FAMILY=clip
EMBED_DIM=512
EMBED_IMAGE_SIZE=224

# Canonical DB path inside app container
DB_PATH=/data/vinylkeeper.db
