FROM golang:1.26.1-alpine AS build

WORKDIR /src

COPY app/go.mod app/go.sum ./app/
RUN go -C app mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go -C app build -o /out/vinyl-keeper .

FROM alpine:latest

WORKDIR /app

COPY --from=build /out/vinyl-keeper /usr/local/bin/vinyl-keeper

EXPOSE 8080

CMD ["vinyl-keeper"]
