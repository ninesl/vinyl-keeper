# Set LAN_IP to your computer's local network IP
# Find it with: ip addr show | grep "inet " | grep -v 127.0.0.1
# Example: LAN_IP=192.168.1.173
LAN_IP=

# Docker-only settings (used by containers)
DB_PATH=/data/vinylkeeper.db
IMAGE_SERVICE_HOST=image-service
IMAGE_SERVICE_PORT=8000
IMAGE_SERVICE_ENDPOINT=/embed

EMBED_MODEL_PATH=models/clip-vit-b-32.onnx
EMBED_MODEL_FAMILY=clip
EMBED_DIM=512
EMBED_IMAGE_SIZE=224
